{
  "name": "zero-to-app",
  "version": "3.3.0",
  "description": "React Native components for building cross-platform apps with Material Design.",
  "license": "MIT",
  "author": "Alex Amayo",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alex-Amayo/zero-to-app.git"
  },
  "homepage": "https://zero-to-app.expo.app",
  "keywords": [
    "react-native",
    "expo",
    "ui-components",
    "design-system",
    "cross-platform",
    "ios",
    "android",
    "web",
    "theming",
    "components"
  ],
  "bin": {
    "zero-to-app": "./dist/mcp/server.mjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./brand": {
      "types": "./dist/brand/index.d.ts",
      "default": "./dist/brand/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "default": "./dist/theme/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./context": {
      "types": "./dist/context/scroll-context.d.ts",
      "default": "./dist/context/scroll-context.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "default": "./dist/components/*/index.js"
    },
    "./components/*/*": {
      "types": "./dist/components/*/*.d.ts",
      "default": "./dist/components/*/*.js"
    },
    "./ui": {
      "types": "./dist/components/ui/index.d.ts",
      "default": "./dist/components/ui/index.js"
    },
    "./ui/*": {
      "types": "./dist/components/ui/*.d.ts",
      "default": "./dist/components/ui/*.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "default": "./dist/icons/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json && pnpm run build:mcp",
    "build:manifest": "tsx mcp/build-manifest.ts",
    "build:mcp": "tsx mcp/build-manifest.ts && esbuild mcp/server.ts --bundle --platform=node --format=esm --outfile=dist/mcp/server.mjs --banner:js='#!/usr/bin/env node' && rm -rf dist/mcp/skills && cp -r ../.claude/skills dist/mcp/skills"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.4.0"
  },
  "peerDependencies": {
    "@expo/ui": "*",
    "@expo/vector-icons": "*",
    "@react-native-community/slider": "*",
    "expo-image": "*",
    "expo-router": "*",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*"
  },
  "peerDependenciesMeta": {
    "@expo/ui": {
      "optional": false
    },
    "@expo/vector-icons": {
      "optional": true
    },
    "@react-native-community/slider": {
      "optional": true
    },
    "expo-image": {
      "optional": true
    },
    "expo-router": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": false
    },
    "react-native-safe-area-context": {
      "optional": false
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "expo-router": "~56.2.8",
    "jest": "^30.2.0",
    "react-test-renderer": "^19.2.4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3"
  }
}
